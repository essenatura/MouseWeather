    <!-- Help Dialog -->
    <string name="help_title">What do these symbols mean? 🧀</string>
    <string name="help_weights">🌡️ **Weights**: Percentage of data from Open-Meteo (OM), Yr.no (Yr), and ICON model in the consensus.</string>
    <string name="help_humidity">💧 **Humidity**: Water vapor content in the air.</string>
    <string name="help_pressure">⏲️ **Pressure**: Atmospheric pressure in hPa.</string>
    <string name="help_uv">☀️ **UV**: Ultraviolet index (over 7 protect the fur!).</string>
    <string name="help_aqi">🇪🇺/🇺🇸 **AQI**: Air Quality Index. App automatically chooses EU or US standard based on country.</string>
    <string name="help_pm25">🌫️ **PM2.5**: Particulate matter up to 2.5 μm. Tiny particles that can enter the bloodstream.</string>
    <string name="help_pm10">☁️ **PM10**: Particulate matter up to 10 μm. Can cause coughing and sneezing.</string>
    <string name="help_gases">🧪 **Gases (CO, NO2, SO2, O3)**: Concentrations of carbon monoxide, nitrogen dioxide, etc.</string>
    <string name="help_wind">💨 **Wind**: Wind speed and direction.</string>
    <string name="help_pollen">🤧 **Pollen**: Information about pollen concentrations.</string>
    <string name="help_no_rain">🌲 **no rain**: Time windows without rain.</string>
    <string name="help_sun">☀️ **Sun**: Windows with low cloud cover (perfect for tanning).</string>
    <string name="help_understand">I understand!</string>

