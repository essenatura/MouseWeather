    <!-- Help Dialog -->
    <string name="help_title">¿Qué significan estos símbolos? 🧀</string>
    <string name="help_weights">🌡️ **Pesos**: Porcentaje de datos de Open-Meteo, Yr.no y modelo ICON.</string>
    <string name="help_humidity">💧 **Humedad**: Contenido de vapor de agua en el aire.</string>
    <string name="help_pressure">⏲️ **Presión**: Presión atmosférica en hPa.</string>
    <string name="help_uv">☀️ **UV**: Índice ultravioleta (¡más de 7 protege el pelaje!).</string>
    <string name="help_aqi">🇪🇺/🇺🇸 **AQI**: Índice de calidad del aire. La aplicación elige el estándar automáticamente.</string>
    <string name="help_pm25">🌫️ **PM2.5**: Partículas de hasta 2.5 μm. Pueden entrar en el torrente sanguíneo.</string>
    <string name="help_pm10">☁️ **PM10**: Partículas de hasta 10 μm. Pueden causar tos.</string>
    <string name="help_gases">🧪 **Gases (CO, NO2, SO2, O3)**: Concentraciones de monóxido de carbono, etc.</string>
    <string name="help_wind">💨 **Viento**: Velocidad y dirección del viento.</string>
    <string name="help_pollen">🤧 **Polen**: Información sobre la concentración de polen.</string>
    <string name="help_no_rain">🌲 **sin lluvia**: Ventanas de tiempo sin lluvia.</string>
    <string name="help_sun">☀️ **Sol**: Ventanas con poca nubosidad (ideal para broncearse).</string>
    <string name="help_understand">¡Entiendo!</string>

