    <string name="mouse_evening">Wieczór idzie! Myszka liczy gwiazdy przed snem. 🌟🐭</string>

    <!-- Help Dialog -->
    <string name="help_title">Co oznaczają te symbole? 🧀</string>
    <string name="help_weights">🌡️ **Wagi**: Procentowy udział danych z portali Open-Meteo (OM), Yr.no (Yr) i modelu ICON w obliczonym konsensusie temperatury.</string>
    <string name="help_humidity">💧 **Wilgotność**: Zawartość pary wodnej w powietrzu.</string>
    <string name="help_pressure">⏲️ **Ciśnienie**: Ciśnienie atmosferyczne w hPa.</string>
    <string name="help_uv">☀️ **UV**: Indeks promieniowania ultrafioletowego (powyżej 7 chroń futerko!).</string>
    <string name="help_aqi">🇪🇺/🇺🇸 **AQI**: Indeks jakości powietrza. Aplikacja automatycznie wybiera standard europejski lub amerykański zależnie od kraju.</string>
    <string name="help_pm25">🌫️ **PM2.5**: Pyły zawieszone o średnicy do 2.5 μm. Bardzo drobne, mogą docierać do krwiobiegu myszki.</string>
    <string name="help_pm10">☁️ **PM10**: Pyły zawieszone o średnicy do 10 μm. Mogą powodować kaszel i katar u myszki.</string>
    <string name="help_gases">🧪 **Gazy (CO, NO2, SO2, O3)**: Stężenie tlenku węgla, dwutlenku azotu, dwutlenku siarki i ozonu.</string>
    <string name="help_wind">💨 **Wiatr**: Prędkość i kierunek wiatru.</string>
    <string name="help_pollen">🤧 **Pylenie**: Informacja o stężeniu pyłków (Olcha, Brzoza, Trawy, Bylica, Oliwka, Ambrozja).</string>
    <string name="help_no_rain">🌲 **bez deszczu**: Okienka czasowe bez opadów deszczu.</string>
    <string name="help_sun">☀️ **Słońce**: Okienka z małym zachmurzeniem (idealne na opalanie).</string>
    <string name="help_understand">Rozumiem!</string>

